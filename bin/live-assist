#!/usr/bin/env bash
# =============================================================================
# Live Assist CLI — manage Docker and get agent feedback from bash
#
# Commands: start, stop, status, logs, agents, feedback
# =============================================================================

set -euo pipefail

INSTALL_DIR="${LIVE_ASSIST_DIR:-$HOME/live-assist}"
AGENT_URL="${LIVE_ASSIST_AGENT_URL:-http://localhost:8765}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${CYAN}[live-assist]${NC} $*"; }
ok()    { echo -e "${GREEN}[live-assist]${NC} $*"; }
warn()  { echo -e "${YELLOW}[live-assist]${NC} $*"; }
fail()  { echo -e "${RED}[live-assist]${NC} $*"; exit 1; }

cmd_start() {
  cd "$INSTALL_DIR" || fail "Install dir not found: $INSTALL_DIR. Run the installer first."
  docker compose -f docker-compose.yml up -d
  ok "Live Assist started."
}

cmd_stop() {
  cd "$INSTALL_DIR" || fail "Install dir not found: $INSTALL_DIR"
  docker compose -f docker-compose.yml down
  ok "Live Assist stopped."
}

cmd_status() {
  local asr_ok=0 agent_ok=0
  if curl -sf "http://localhost:8001/" >/dev/null 2>&1; then asr_ok=1; fi
  if curl -sf "$AGENT_URL/health" >/dev/null 2>&1; then agent_ok=1; fi
  if [ "$asr_ok" = 1 ] && [ "$agent_ok" = 1 ]; then
    ok "Running — ASR and Agent healthy."
  else
    warn "Not running or unhealthy. ASR: $([ $asr_ok = 1 ] && echo OK || echo FAIL), Agent: $([ $agent_ok = 1 ] && echo OK || echo FAIL)"
    exit 1
  fi
}

cmd_logs() {
  docker logs -f live-assist 2>/dev/null || fail "Container not running. Run: live-assist start"
}

cmd_agents() {
  local res
  res=$(curl -sf "$AGENT_URL/live-assist/agents" 2>/dev/null) || fail "Agent not reachable. Run: live-assist start"
  echo "$res" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    for a in d.get('agents', []):
        print(f\"  {a['id']:20} — {a['name']}: {a['description']}\")
except Exception:
    print(sys.stdin.read())
" 2>/dev/null || echo "$res"
}

cmd_feedback() {
  local agent="${LIVE_ASSIST_AGENT:-default}" transcript=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent) agent="$2"; shift 2 ;;
      --transcript) transcript="$2"; shift 2 ;;
      *) transcript="$1"; shift ;;
    esac
  done
  if [ -z "$transcript" ]; then
    transcript=$(cat)
  fi
  if [ -z "$transcript" ] || [ ${#transcript} -lt 10 ]; then
    fail "Transcript too short. Usage: live-assist feedback [--agent ID] [--transcript TEXT] or pipe text."
  fi

  local body
  body=$(printf '%s' "$transcript" | python3 -c "
import json, sys
t = sys.stdin.read()
print(json.dumps({'transcript': t, 'agent_id': sys.argv[1], 'mode': 'meeting', 'user_id': 'cli'}))
" "$agent" 2>/dev/null) || fail "Python3 required for feedback command."

  curl -sf -X POST "$AGENT_URL/live-assist/process/stream" \
    -H "Content-Type: application/json" \
    -d "$body" \
    --max-time 60 \
    --no-buffer 2>/dev/null | while read -r line; do
    if [[ "$line" == data:* ]]; then
      local raw="${line#data: }"
      if [ "$raw" = "[DONE]" ] || [ -z "$raw" ]; then continue; fi
      local type summary suggestions
      type=$(echo "$raw" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('type',''))" 2>/dev/null)
      if [ "$type" = "feedback" ]; then
        summary=$(echo "$raw" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('data',{}).get('summary',''))" 2>/dev/null)
        suggestions=$(echo "$raw" | python3 -c "import json,sys; d=json.load(sys.stdin); print('\\n'.join(d.get('data',{}).get('suggestions',[])))" 2>/dev/null)
        echo ""
        echo -e "${BOLD}Summary:${NC} $summary"
        if [ -n "$suggestions" ]; then
          echo -e "${BOLD}Suggestions:${NC}"
          echo "$suggestions" | sed 's/^/  • /'
        fi
      elif [ "$type" = "done" ]; then
        break
      fi
    fi
  done || fail "Agent not reachable. Run: live-assist start"
}

cmd_help() {
  echo "Live Assist CLI — manage Docker and get agent feedback"
  echo ""
  echo "Usage: live-assist <command> [options]"
  echo ""
  echo "Commands:"
  echo "  start      Start Live Assist (Docker)"
  echo "  stop       Stop Live Assist"
  echo "  status     Check if ASR and Agent are healthy"
  echo "  logs       Tail container logs"
  echo "  agents     List available smart agents"
  echo "  feedback   Get agent feedback for text (from arg, --transcript, or stdin)"
  echo ""
  echo "Examples:"
  echo "  live-assist start"
  echo "  live-assist feedback \"We agreed to send the deck by Friday\""
  echo "  live-assist feedback --agent commitment_tracker --transcript \"...\""
  echo "  echo \"Meeting notes...\" | live-assist feedback"
  echo ""
  echo "Env: LIVE_ASSIST_DIR, LIVE_ASSIST_AGENT_URL, LIVE_ASSIST_AGENT"
}

case "${1:-help}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  agents)  cmd_agents ;;
  feedback) shift; cmd_feedback "$@" ;;
  help|--help|-h) cmd_help ;;
  *) fail "Unknown command: $1. Run: live-assist help" ;;
esac
